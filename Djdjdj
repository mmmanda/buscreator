window.guardarSupervisor = async function() {
  const eid = document.getElementById('supervisorEditEid').value;
  const editId = document.getElementById('supervisorEditId').value;
  const nombre = document.getElementById('supervisorNombre').value.trim();
  const dni = document.getElementById('supervisorDni').value.trim();

  if (!nombre || !dni) return toast('Completá nombre y DNI', 'error');

  try {
    if (editId) {
      if(!can('supEdit') && state.auth.role !== 'superadmin') return toast('Sin permisos', 'error');
      await update(ref(db, `empresas/${eid}/supervisores/${editId}`), { nombre, dni });
      toast(`Supervisor actualizado`);
    } else {
      if(!can('supAdd') && state.auth.role !== 'superadmin') return toast('Sin permisos', 'error');
      const nr = push(ref(db, `empresas/${eid}/supervisores`));
      await set(nr, { nombre, dni, creadoEn: Date.now() });
      toast(`Supervisor creado`);
    }
    closeModal('supervisor');
    renderEmpresaView(eid);
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

