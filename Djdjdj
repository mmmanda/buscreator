<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COLECTUCUS Admin Panel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:       #0d0f12;
    --surface:  #151820;
    --panel:    #1c2030;
    --border:   #2a3045;
    --accent:   #f4a318;
    --accent2:  #3b82f6;
    --danger:   #ef4444;
    --success:  #22c55e;
    --warn:     #eab308;
    --text:     #e8eaf0;
    --muted:    #6b7490;
    --tag-u:    #3b82f6;
    --tag-i:    #a855f7;
    --tag-r:    #22c55e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; min-height: 100vh; overflow-x: hidden; }

  /* ─── LOGIN OVERLAY ─── */
  .login-overlay {
    position: fixed; inset: 0; background: var(--bg); z-index: 9999;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1.5rem;
  }
  .login-box {
    background: var(--surface); border: 1px solid var(--border); border-top: 4px solid var(--accent);
    border-radius: 12px; padding: 2.5rem 2rem; width: 100%; max-width: 440px; box-shadow: 0 10px 40px rgba(0,0,0,0.8);
    text-align: center; transition: all 0.3s ease;
  }
  .login-box h2 { font-family: 'Bebas Neue'; color: var(--text); letter-spacing: 4px; font-size: 2.2rem; margin-bottom: 0.5rem; }
  .login-box h2 span { color: var(--accent); }
  .login-box p.desc { color: var(--muted); font-size: 0.85rem; margin-bottom: 2rem; }
  .login-error { color: var(--danger); font-size: 0.85rem; margin-top: 1rem; display: none; background: rgba(239,68,68,0.1); padding: 0.5rem; border-radius: 4px; border: 1px solid rgba(239,68,68,0.3); }

  .empresa-greeting { display: none; flex-direction: column; align-items: center; margin-bottom: 1.5rem; animation: popIn 0.3s ease; }
  .empresa-greeting .bus-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .empresa-greeting h3 { color: var(--accent); font-family: 'Bebas Neue'; font-size: 1.6rem; letter-spacing: 1px; }

  /* ─── TOPBAR ─── */
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.5rem; height: 60px;
    background: var(--surface); border-bottom: 2px solid var(--accent);
    position: sticky; top: 0; z-index: 1000;
  }
  .topbar-left { display: flex; align-items: center; gap: 15px; }
  .menu-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.5rem; cursor: pointer; }
  .logo { font-family: 'Bebas Neue'; font-size: 1.6rem; letter-spacing: 4px; display: flex; align-items: center; gap: 8px;}
  .logo .c1 { color: var(--accent); }
  .logo .c2 { color: var(--text); }
  .logo .c3 { color: var(--muted); font-size: 0.9rem; letter-spacing: 2px; }
  .auth-info { display: flex; align-items: center; gap: 10px; }
  .user-badge { background: var(--panel); border: 1px solid var(--border); padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-family: 'DM Mono'; color: var(--accent); white-space: nowrap;}
  .btn-logout { background: none; border: 1px solid var(--border); color: var(--muted); padding: 4px 8px; border-radius: 4px; cursor: pointer; font-family: 'DM Mono'; font-size: 0.7rem; transition: all 0.2s; white-space: nowrap;}
  .btn-logout:hover { background: var(--danger); color: #fff; border-color: var(--danger); }
  
  .db-status { display: flex; align-items: center; gap: 6px; font-family: 'DM Mono'; font-size: .7rem; color: var(--muted); margin-left:10px; border-left: 1px solid var(--border); padding-left: 10px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); transition: background .3s; }
  .dot.ok  { background: var(--success); box-shadow: 0 0 6px var(--success); }
  .dot.err { background: var(--danger);  box-shadow: 0 0 6px var(--danger); }

  /* ─── LAYOUT ─── */
  .layout { display: flex; min-height: calc(100vh - 60px); position: relative; }

  /* ─── SIDEBAR ─── */
  .sidebar { width: 320px; flex-shrink: 0; background: var(--surface); border-right: 1px solid var(--border); padding: 1.5rem 1rem; overflow-y: auto; transition: transform 0.3s ease; }
  .sidebar-title { font-family: 'Bebas Neue'; font-size: 1rem; letter-spacing: 3px; color: var(--muted); padding: 0 .5rem .8rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  .empresa-item { border: 1px solid var(--border); border-radius: 6px; margin-bottom: .6rem; overflow: hidden; transition: border-color .2s; }
  .empresa-item.active { border-color: var(--accent); }
  .empresa-header { display: flex; align-items: center; gap: 6px; padding: .75rem 1rem; cursor: pointer; background: var(--panel); transition: background .2s; }
  .empresa-header:hover { background: #222840; }
  .empresa-name { font-weight: 700; font-size: .9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
  .empresa-arrow { font-size: .7rem; color: var(--muted); transition: transform .25s; }
  .empresa-item.open .empresa-arrow { transform: rotate(90deg); }
  .icon-btn { background: none; border: none; cursor: pointer; padding: 2px 5px; border-radius: 3px; font-size: .8rem; opacity: .5; transition: opacity .2s, background .2s; }
  .icon-btn:hover { opacity: 1; background: rgba(255,255,255,.07); }
  .icon-btn.edit  { color: var(--warn); }
  .icon-btn.del   { color: var(--danger); }
  .lineas-list { display: none; background: var(--bg); padding: .4rem .5rem; }
  .empresa-item.open .lineas-list { display: block; }
  .linea-item { display: flex; align-items: center; gap: 4px; padding: .45rem .6rem; border-radius: 4px; cursor: pointer; font-size: .82rem; transition: background .15s; }
  .linea-item:hover { background: var(--panel); }
  .linea-item.active { background: rgba(244,163,24,.12); color: var(--accent); }
  .linea-item-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tipo-badge { font-family: 'DM Mono'; font-size: .65rem; padding: 1px 5px; border-radius: 3px; font-weight: 500; white-space: nowrap; }
  .tipo-badge.U { background: rgba(59,130,246,.25); color: var(--tag-u); }
  .tipo-badge.I { background: rgba(168,85,247,.25); color: var(--tag-i); }
  .tipo-badge.R { background: rgba(34,197,94,.25);  color: var(--tag-r); }
  .add-empresa-btn { width: 100%; margin-top: 1rem; padding: .7rem; background: transparent; border: 1px dashed var(--accent); border-radius: 6px; color: var(--accent); font-family: 'Syne'; font-size: .85rem; font-weight: 600; cursor: pointer; transition: background .2s; }
  .add-empresa-btn:hover { background: rgba(244,163,24,.08); }

  /* ─── MAIN ─── */
  .main { flex: 1; padding: 2rem; overflow-y: auto; background: var(--bg); width: 100%; }
  .breadcrumb { font-family: 'DM Mono'; font-size: .75rem; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .breadcrumb .sep { color: var(--border); }
  .breadcrumb .crumb { color: var(--text); }
  .breadcrumb .link { color: var(--accent2); cursor: pointer; text-decoration: underline; }
  .section-title { font-family: 'Bebas Neue'; font-size: 1.6rem; letter-spacing: 3px; color: var(--accent); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 12px; }
  .section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* ─── TABS ─── */
  .tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); overflow-x: auto;}
  .tab-btn { padding: .7rem 1.2rem; background: none; border: none; color: var(--muted); font-family: 'Syne'; font-size: .85rem; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .2s, border-color .2s; letter-spacing: .5px; white-space: nowrap;}
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ─── CARDS ─── */
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; padding: 1.2rem; transition: border-color .2s, transform .15s; }
  .card:hover { border-color: var(--accent2); transform: translateY(-1px); }
  .card-id { font-family: 'DM Mono'; font-size: .65rem; color: var(--muted); margin-bottom: .5rem; }
  .card-title { font-size: 1rem; font-weight: 700; margin-bottom: .3rem; }
  .card-sub { font-size: .8rem; color: var(--muted); margin-top: .2rem; }
  .card-actions { display: flex; gap: 6px; margin-top: .9rem; flex-wrap: wrap; }
  .btn-sm { padding: 4px 10px; border-radius: 4px; font-family: 'DM Mono'; font-size: .72rem; border: none; cursor: pointer; transition: opacity .2s; font-weight: 500; }
  .btn-sm:hover { opacity: .8; }
  .btn-sm.primary { background: var(--accent); color: #000; }
  .btn-sm.edit    { background: rgba(234,179,8,.15); color: var(--warn); border: 1px solid rgba(234,179,8,.3); }
  .btn-sm.danger  { background: rgba(239,68,68,.15); color: var(--danger); border: 1px solid rgba(239,68,68,.3); }
  .btn-sm.cancel  { background: transparent; color: var(--muted); border: 1px solid var(--border); }

  /* ─── FORM ─── */
  .field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 1.2rem; text-align: left;}
  .field label { font-size: .75rem; font-weight: 600; letter-spacing: 1px; color: var(--muted); text-transform: uppercase; }
  .field input, .field select, .field textarea { background: var(--bg); border: 1px solid var(--border); border-radius: 5px; color: var(--text); font-family: 'DM Mono'; font-size: .85rem; padding: .7rem .8rem; outline: none; transition: border-color .2s; width: 100%; }
  .field input:disabled, .field select:disabled, .field textarea:disabled { opacity: 0.5; cursor: not-allowed; }
  .field input:focus:not(:disabled), .field select:focus:not(:disabled), .field textarea:focus:not(:disabled) { border-color: var(--accent); }
  .field select option { background: var(--panel); }
  .field textarea { resize: vertical; min-height: 110px; }
  .submit-btn { padding: .7rem 2rem; background: var(--accent); color: #000; font-family: 'Bebas Neue'; font-size: 1.1rem; letter-spacing: 2px; border: none; border-radius: 5px; cursor: pointer; transition: opacity .2s, transform .1s; width: 100%;}
  @media (min-width: 480px) { .submit-btn { width: auto; } }
  .submit-btn:hover { opacity: .88; }
  .submit-btn:active { transform: scale(.97); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  /* ─── CREDENCIALES (APODOS) ─── */
  .cred-list-item { display: flex; justify-content: space-between; align-items: center; background: var(--bg); border: 1px solid var(--border); padding: 0.8rem 1rem; border-radius: 6px; margin-bottom: 0.5rem; }
  .cred-info { display: flex; flex-direction: column; gap: 3px; }
  .cred-apodo { font-weight: bold; font-size: 0.9rem; color: var(--text); }
  .cred-pass { font-family: 'DM Mono'; font-size: 0.7rem; color: var(--muted); }
  
  /* ─── PERMISOS GRID GRANULAR ─── */
  .perm-grid-granular { display: grid; grid-template-columns: 1fr; gap: 0.4rem; background: var(--bg); padding: 1rem; border-radius: 6px; border: 1px solid var(--border); max-height: 250px; overflow-y: auto;}
  @media (min-width: 600px) { .perm-grid-granular { grid-template-columns: 1fr 1fr; } }
  .perm-grid-granular label { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; color: var(--text); text-transform: none; cursor: pointer; padding: 4px 0;}
  .perm-grid-granular input[type="checkbox"] { width: 14px; height: 14px; margin: 0; cursor: pointer; accent-color: var(--accent); flex-shrink: 0;}

  /* ─── COORDS PREVIEW ─── */
  .coords-info { background: rgba(59,130,246,.07); border: 1px solid rgba(59,130,246,.2); border-radius: 6px; padding: .8rem 1rem; font-family: 'DM Mono'; font-size: .75rem; color: var(--muted); margin-bottom: 1rem; }
  .coords-info strong { color: var(--accent2); }
  .coords-count { display: inline-block; margin-top: .4rem; background: rgba(34,197,94,.15); color: var(--success); padding: 2px 8px; border-radius: 10px; font-size: .72rem; }
  .preview-map { width: 100%; height: 200px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; position: relative; overflow: hidden; margin-top: .5rem; display: none; }

  /* ─── GRILLA DE HORARIOS ─── */
  .grilla-table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; font-family: 'DM Mono'; font-size: 0.75rem; color: var(--text); background: var(--panel); border: 1px solid var(--border); }
  .grilla-table th, .grilla-table td { border: 1px solid var(--border); padding: 0.5rem; text-align: left; vertical-align: middle; }
  .grilla-table th { background: #222840; color: var(--accent); text-transform: uppercase; font-size: 0.65rem; letter-spacing: 1px;}
  .grilla-table input[type="text"], .grilla-table input[type="time"] { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); padding: 6px; border-radius: 4px; outline: none; font-family: 'DM Mono'; }
  .grilla-table input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(1); cursor: pointer; }
  .grilla-table input:focus { border-color: var(--accent); }
  .grilla-table input:disabled { opacity: 0.5; cursor: not-allowed; }
  .dias-checkboxes { display: flex; gap: 6px; flex-wrap: wrap; min-width: 140px; }
  .dias-checkboxes label { display: flex; align-items: center; gap: 3px; font-size: 0.65rem; cursor: pointer; }
  .dias-checkboxes input[type="checkbox"] { width: 12px; height: 12px; accent-color: var(--accent); cursor: pointer;}
  .btn-del-grid { background: rgba(239,68,68,.15); color: var(--danger); border: 1px solid rgba(239,68,68,.3); border-radius: 3px; cursor: pointer; padding: 2px 6px; font-weight: bold; transition: background .2s;}
  .btn-del-grid:hover { background: var(--danger); color: #fff; }

  /* ─── TOAST ─── */
  .toast-container { position: fixed; bottom: 2rem; right: 2rem; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
  .toast { background: var(--panel); border-left: 4px solid var(--success); border-radius: 4px; padding: .8rem 1.2rem; font-size: .82rem; box-shadow: 0 4px 20px rgba(0,0,0,.5); animation: slideIn .3s ease, fadeOut .4s 2.6s ease forwards; max-width: 320px; }
  .toast.error { border-left-color: var(--danger); }
  @keyframes slideIn { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes fadeOut { to { opacity: 0; transform: translateX(100px); } }

  /* ─── MODAL ─── */
  .modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(3px); }
  .modal-bg.open { display: flex; }
  .modal { background: var(--panel); border: 1px solid var(--border); border-top: 3px solid var(--accent); border-radius: 10px; padding: 1.5rem; width: 600px; max-width: 92vw; max-height: 90vh; overflow-y: auto; animation: popIn .2s ease; }
  @media (min-width: 480px) { .modal { padding: 2rem; } }
  .modal.warn-modal { border-top-color: var(--danger); width: 400px; }
  @keyframes popIn { from { transform: scale(.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .modal h3 { font-family: 'Bebas Neue'; font-size: 1.4rem; letter-spacing: 2px; color: var(--accent); margin-bottom: 1.4rem; }
  .modal.warn-modal h3 { color: var(--danger); }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap;}
  .btn-cancel { padding: .6rem 1.2rem; background: transparent; border: 1px solid var(--border); border-radius: 5px; color: var(--muted); font-family: 'Syne'; font-size: .85rem; cursor: pointer; flex-grow: 1; text-align: center;}
  @media (min-width: 480px) { .btn-cancel { flex-grow: 0; } }
  .btn-cancel:hover { border-color: var(--text); color: var(--text); }
  .btn-danger { padding: .6rem 1.2rem; background: var(--danger); border: none; border-radius: 5px; color: #fff; font-family: 'Bebas Neue'; font-size: 1.1rem; letter-spacing: 1px; cursor: pointer; flex-grow: 1; text-align: center;}
  @media (min-width: 480px) { .btn-danger { flex-grow: 0; } }

  /* ─── EMPTY / PLACEHOLDER ─── */
  .empty { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: .85rem; }
  .empty .big { font-family: 'Bebas Neue'; font-size: 3rem; display: block; opacity: .15; margin-bottom: 0.5rem;}
  .placeholder-msg { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 400px; text-align: center; color: var(--muted); padding: 2rem;}
  .placeholder-msg .icon { font-size: 3rem; opacity: .2; margin-bottom: 1rem; }

  /* MOBILE ADAPTATION */
  .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 900; backdrop-filter: blur(2px); }
  @media (max-width: 768px) {
    .menu-toggle { display: block; }
    .sidebar { position: fixed; top: 60px; left: -320px; bottom: 0; z-index: 950; height: calc(100vh - 60px); }
    .sidebar.open { left: 0; transform: translateX(0); }
    .sidebar-overlay.open { display: block; }
    .form-row { grid-template-columns: 1fr; gap: 0; }
    .main { padding: 1.5rem 1rem; }
    .auth-info .db-status { display: none; } /* Hide text on very small screens to save space */
  }
</style>
</head>
<body>

<!-- ─── LOGIN OVERLAY ─── -->
<div class="login-overlay" id="loginOverlay">
  <div class="login-box">
    
    <!-- PASO 1: ID -->
    <div id="loginStep1">
      <h2><span>COLEC</span>TUCUS <span>ADMIN</span></h2>
      <p class="desc">Ingresá tu ID de Empresa para acceder.</p>
      <div class="field">
        <label>ID de Empresa / Código</label>
        <input type="text" id="loginId" placeholder="Ej: CENTRAL o ID Firebase" autocomplete="off">
      </div>
      <button class="submit-btn" style="width:100%; margin-top:0.5rem;" onclick="checkLoginId()">SIGUIENTE</button>
    </div>

    <!-- PASO 2: CONTRASEÑA -->
    <div id="loginStep2" style="display:none;">
      <div class="empresa-greeting" id="empresaGreeting">
        <div class="bus-icon">🚌</div>
        <h3 id="loginCompanyName">Nombre Empresa</h3>
      </div>
      <p class="desc">Ingresá tu contraseña asignada.</p>
      <div class="field">
        <label>Contraseña</label>
        <input type="password" id="loginPass" placeholder="Tu contraseña" autocomplete="off">
      </div>
      <div style="display:flex; gap:10px; margin-top:1rem;">
        <button class="btn-cancel" style="width:40%;" onclick="resetLogin()">VOLVER</button>
        <button class="submit-btn" style="width:60%;" onclick="doLogin()">ENTRAR</button>
      </div>
    </div>

    <p class="login-error" id="loginError"></p>
  </div>
</div>

<!-- ─── TOPBAR ─── -->
<header class="topbar">
  <div class="topbar-left">
    <button class="menu-toggle" onclick="toggleMobileMenu()">☰</button>
    <div class="logo">
      <span class="c1">COLEC</span><span class="c2">TUCUS</span> <span class="c3">ADMIN</span>
    </div>
  </div>
  <div class="auth-info" id="authInfo" style="display:none;">
    <span class="user-badge" id="userBadge">Invitado</span>
    <button class="btn-logout" onclick="doLogout()">Salir</button>
    <div class="db-status">
      <div class="dot" id="dbDot"></div>
      <span id="dbLabel">Conectando...</span>
    </div>
  </div>
</header>

<div class="layout">
  <!-- ─── SIDEBAR ─── -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMobileMenu()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-title">EMPRESAS / LÍNEAS</div>
    <div id="empresasList"><div class="empty"><small>Cargando datos...</small></div></div>
    <button class="add-empresa-btn" id="btnSidebarAddEmpresa" style="display:none;" onclick="openModal('empresa')">+ Nueva Empresa</button>
  </aside>
  
  <!-- ─── MAIN CONTENT ─── -->
  <main class="main" id="mainContent">
    <div class="placeholder-msg">
      <div class="icon">🚌</div>
      <p>Seleccioná una línea del panel izquierdo para comenzar.</p>
    </div>
  </main>
</div>

<div class="toast-container" id="toastContainer"></div>

<!-- ─── MODAL: EMPRESA ─── -->
<div class="modal-bg" id="modalEmpresa">
  <div class="modal">
    <h3 id="modalEmpresaTitle">➕ NUEVA EMPRESA</h3>
    <input type="hidden" id="empEditId">
    
    <div class="form-row">
      <div class="field">
        <label>Nombre de Empresa</label>
        <input type="text" id="empNombre" placeholder="Ej: Empresa Central S.A.">
      </div>
      <div class="field">
        <label>Código Interno</label>
        <input type="text" id="empCodigo" placeholder="Ej: CENTRAL">
      </div>
    </div>

    <!-- Lista de Apodos (Superadmin view) -->
    <div id="adminCredsSection" style="display:none; margin-top:1rem; border-top:1px solid var(--border); padding-top:1.5rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <h4 style="color:var(--accent); font-family:'Bebas Neue'; letter-spacing:1px; font-size:1.1rem;">🔑 APODOS Y CREDENCIALES</h4>
        <button class="btn-sm primary" onclick="abrirNuevaCredencial()">+ NUEVO APODO</button>
      </div>
