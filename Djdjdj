<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getDatabase, ref, push, set, remove, onValue, update } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyDkwkVn3j-FAAPLGqh0frlWnNozU1fiLVY",
  authDomain: "colectucus.firebaseapp.com",
  databaseURL: "https://colectucus-default-rtdb.firebaseio.com",
  projectId: "colectucus",
  storageBucket: "colectucus.firebasestorage.app",
  messagingSenderId: "686986656402",
  appId: "1:686986656402:web:0d22ac7a8e99f3aea5844b"
};

const app = initializeApp(firebaseConfig);
const db  = getDatabase(app);

// ESTADO GLOBAL + AUTENTICACIÓN
let state = { 
  superadminKey: null,
  empresas: {}, 
  selectedEmpresaId: null, 
  selectedLineaId: null,
  dbLoaded: false,
  auth: {
    role: null,
    eid: null, 
    alias: '',
    perms: {} 
  },
  tempCreds: {} 
};

// ── CONEXIÓN ──────────────────────────────────────────────────────
onValue(ref(db, '.info/connected'), snap => {
  const ok = snap.val();
  document.getElementById('dbDot').className    = 'dot ' + (ok ? 'ok' : 'err');
  document.getElementById('dbLabel').textContent = ok ? 'Conectado' : 'Desconectado';
});

// ── ESCUCHAR DATOS DE FIREBASE ────────────────────────────────────
onValue(ref(db, 'empresas'), snap => {
  state.empresas = snap.val() || {};
  state.dbLoaded = true;
  if (state.auth.role) {
    renderSidebar();
    if (state.selectedEmpresaId) {
      if (state.selectedLineaId) renderLineaView(state.selectedEmpresaId, state.selectedLineaId);
      else renderEmpresaView(state.selectedEmpresaId);
    }
  }
});

// ESCUCHAR LLAVE DE SUPERADMIN
onValue(ref(db, 'config/superadminKey'), snap => {
  state.superadminKey = snap.val();
});

// ══════════════════════════════════════════════════════════════════
//  MOBILE MENU
// ══════════════════════════════════════════════════════════════════
window.toggleMobileMenu = function() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('open');
}
function closeMobileMenuIfOpen() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
}

// ══════════════════════════════════════════════════════════════════
//  SISTEMA DE LOGIN Y PERMISOS (2 PASOS)
// ══════════════════════════════════════════════════════════════════
let loginTempEid = null;

window.checkLoginId = function() {
  if (!state.dbLoaded) return showLoginError("Conectando con la base de datos...");
  const inputId = document.getElementById('loginId').value.trim();
  if(!inputId) return showLoginError("Ingresa un ID válido.");

  if (state.superadminKey && inputId === state.superadminKey) {
    state.auth = { role: 'superadmin', eid: null, alias: 'Superadmin', perms: {} };
    concederAcceso();
    return;
  }

  let empresaEncontradaId = null;
  let empresaObj = null;
  for (const [key, emp] of Object.entries(state.empresas)) {
    if (key === inputId || emp.codigo === inputId) {
      empresaEncontradaId = key;
      empresaObj = emp;
      break;
    }
  }

  if (!empresaEncontradaId) {
    showLoginError("No se encontró ninguna empresa con ese ID.");
    return;
  }

  loginTempEid = empresaEncontradaId;
  document.getElementById('loginError').style.display = 'none';
  document.getElementById('loginStep1').style.display = 'none';
  document.getElementById('loginStep2').style.display = 'block';
  document.getElementById('empresaGreeting').style.display = 'flex';
  document.getElementById('loginCompanyName').textContent = empresaObj.nombre;
}

window.resetLogin = function() {
  loginTempEid = null;
  document.getElementById('loginStep2').style.display = 'none';
  document.getElementById('empresaGreeting').style.display = 'none';
  document.getElementById('loginStep1').style.display = 'block';
  document.getElementById('loginPass').value = '';
  document.getElementById('loginError').style.display = 'none';
}

window.doLogin = function() {
  const inputPass = document.getElementById('loginPass').value.trim();
  const empresaObj = state.empresas[loginTempEid];

  let credencialValida = null;
  if (empresaObj && empresaObj.credenciales) {
    credencialValida = Object.values(empresaObj.credenciales).find(c => c.password === inputPass);
  }

  if (credencialValida) {
    state.auth = {
      role: 'company',
      eid: loginTempEid,
      alias: credencialValida.apodo || 'Operador',
      perms: credencialValida.permisos || {}
    };
    concederAcceso();
    state.selectedEmpresaId = loginTempEid;
  } else {
    showLoginError("Contraseña incorrecta.");
  }
}

function showLoginError(msg) {
  const errEl = document.getElementById('loginError');
  errEl.textContent = msg;
  errEl.style.display = 'block';
}

function concederAcceso() {
  document.getElementById('loginOverlay').style.display = 'none';
  document.getElementById('authInfo').style.display = 'flex';
  const badge = document.getElementById('userBadge');
  badge.textContent = state.auth.role === 'superadmin' ? 'Superadmin' : state.auth.alias;
  badge.style.color = state.auth.role === 'superadmin' ? 'var(--danger)' : 'var(--accent)';
  document.getElementById('btnSidebarAddEmpresa').style.display = state.auth.role === 'superadmin' ? 'block' : 'none';
  renderSidebar();
  if (state.auth.role === 'company') renderEmpresaView(state.auth.eid);
}

window.doLogout = function() {
  state.auth = { role: null, eid: null, alias: '', perms: {} };
  state.selectedEmpresaId = null; state.selectedLineaId = null;
  resetLogin();
  document.getElementById('loginId').value = '';
  document.getElementById('authInfo').style.display = 'none';
  document.getElementById('loginOverlay').style.display = 'flex';
  document.getElementById('mainContent').innerHTML = `<div class="placeholder-msg"><div class="icon">🚌</div><p>Seleccioná una empresa del panel izquierdo.</p></div>`;
  document.getElementById('empresasList').innerHTML = '';
}

function can(action) {
  if (state.auth.role === 'superadmin') return true;
  if (state.auth.role === 'company' && state.auth.perms[action]) return true;
  return false;
}

// ══════════════════════════════════════════════════════════════════
//  SIDEBAR
// ══════════════════════════════════════════════════════════════════
window.renderSidebar = function() {
  const el = document.getElementById('empresasList');
  let eids = Object.keys(state.empresas);
  if (state.auth.role === 'company') eids = eids.filter(id => id === state.auth.eid);
  if (!eids.length) { el.innerHTML = '<div class="empty"><small>Sin empresas</small></div>'; return; }
  
  const canEditEmpName = can('empName');
  const canEditEmpId = can('empId');
  const canLinAdd = can('linAdd');
  const canLinDel = can('linDel');
  const canLinEditAny = can('linType') || can('linName') || can('linDest');

  el.innerHTML = eids.map(eid => {
    const emp = state.empresas[eid];
    const lineas = emp.lineas || {};
    const lids = Object.keys(lineas);
    const isOpen = state.selectedEmpresaId === eid;
    
    return `
    <div class="empresa-item ${isOpen ? 'open active' : ''}">
      <div class="empresa-header" onclick="selectEmpresa('${eid}')">
        <span class="empresa-name">${emp.nombre}</span>
        ${(canEditEmpName || canEditEmpId) ? `<button class="icon-btn edit" title="Editar empresa" onclick="event.stopPropagation();abrirEditEmpresa('${eid}')">✏</button>` : ''}
        ${state.auth.role === 'superadmin' ? `<button class="icon-btn del" title="Eliminar empresa" onclick="event.stopPropagation();confirmar('¿Eliminar la empresa <strong>${emp.nombre}</strong>?', ()=>eliminarEmpresa('${eid}'))">🗑</button>` : ''}
        <span class="empresa-arrow">▶</span>
      </div>
      <div class="lineas-list">
        ${lids.length ? lids.map(lid => {
          const l = lineas[lid]; const tc = l.tipo ? l.tipo[0] : 'U';
          return `<div class="linea-item ${state.selectedLineaId === lid ? 'active' : ''}">
            <span class="tipo-badge ${tc}" onclick="selectLinea('${eid}','${lid}')">${tc}</span>
            <span class="linea-item-name" onclick="selectLinea('${eid}','${lid}')">${l.nombre}</span>
            ${canLinEditAny ? `<button class="icon-btn edit" onclick="abrirEditLinea('${eid}','${lid}')">✏</button>` : ''}
            ${canLinDel ? `<button class="icon-btn del" onclick="confirmar('¿Eliminar línea?', ()=>eliminarLinea('${eid}','${lid}'))">🗑</button>` : ''}
          </div>`;
        }).join('') : '<div style="padding:.4rem .75rem;font-size:.75rem;color:var(--muted)">Sin líneas</div>'}
      </div>
    </div>`;
  }).join('');
}

window.selectEmpresa = function(eid) { state.selectedEmpresaId = eid; state.selectedLineaId = null; renderSidebar(); renderEmpresaView(eid); closeMobileMenuIfOpen(); }
window.selectLinea = function(eid, lid) { state.selectedEmpresaId = eid; state.selectedLineaId = lid; renderSidebar(); renderLineaView(eid, lid); closeMobileMenuIfOpen(); }

// ══════════════════════════════════════════════════════════════════
//  VISTA EMPRESA (CON PESTAÑAS LÍNEAS / CHÓFERES / SUPERVISORES)
// ══════════════════════════════════════════════════════════════════
window.renderEmpresaView = function(eid) {
  const emp = state.empresas[eid]; if (!emp) return;
  const lineas = emp.lineas || {}; const lids = Object.keys(lineas);
  const choferes = emp.choferes || {}; const cids = Object.keys(choferes);
  const supervisores = emp.supervisores || {}; const sids = Object.keys(supervisores);
  
  const canLinEditAny = can('linType') || can('linName') || can('linDest');

  document.getElementById('mainContent').innerHTML = `
    <div class="breadcrumb"><span class="crumb">${emp.nombre}</span> <span class="sep" style="margin-left:10px">|</span> <span class="sep" style="font-size:0.65rem; color:var(--muted)">ID Sistema: ${eid}</span></div>
    <div class="section-title">${emp.nombre}</div>
    
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('lineas-emp',this)">Líneas (${lids.length})</button>
      <button class="tab-btn"        onclick="switchTab('choferes-emp',this)">Chóferes (${cids.length})</button>
      <button class="tab-btn"        onclick="switchTab('supervisores-emp',this)">Supervisores (${sids.length})</button>
    </div>

    <div class="tab-content active" id="tab-lineas-emp">
      ${can('linAdd') ? `<button class="submit-btn" style="margin-bottom:1.5rem" onclick="openModal('linea');document.getElementById('lineaEditId').value='';">+ NUEVA LÍNEA</button>` : ''}
      <div class="cards-grid">
        ${lids.length ? lids.map(lid => {
          const l = lineas[lid]; const tc = l.tipo ? l.tipo[0] : 'U';
          return `<div class="card">
            <div class="card-id">ID: ${lid}</div>
            <div class="card-title"><span class="tipo-badge ${tc}" style="margin-right:6px">${l.tipo}</span>${l.nombre}</div>
            <div class="card-sub">${l.destino || ''}</div>
            <div class="card-actions">
              <button class="btn-sm primary" onclick="selectLinea('${eid}','${lid}')">Gestionar</button>
              ${canLinEditAny ? `<button class="btn-sm edit" onclick="abrirEditLinea('${eid}','${lid}')">Editar</button>` : ''}
              ${can('linDel') ? `<button class="btn-sm danger" onclick="confirmar('¿Eliminar línea?', ()=>eliminarLinea('${eid}','${lid}'))">Eliminar</button>` : ''}
            </div>
          </div>`;
        }).join('') : `<div class="empty"><span class="big">🚌</span>Sin líneas aún</div>`}
      </div>
    </div>

    <div class="tab-content" id="tab-choferes-emp">
      ${can('chofAdd') || state.auth.role === 'superadmin' ? `<button class="submit-btn" style="margin-bottom:1.5rem" onclick="abrirNuevoChofer('${eid}')">+ NUEVO CHÓFER</button>` : ''}
      <div class="cards-grid">
        ${cids.length ? cids.map(cid => {
          const c = choferes[cid];
          return `<div class="card">
            <div class="card-id">ID: ${cid}</div>
            <div class="card-title">👨‍✈️ ${c.nombre}</div>
            <div class="card-sub">DNI: ${c.dni}</div>
            <div class="card-actions">
              ${can('chofEdit') || state.auth.role === 'superadmin' ? `<button class="btn-sm edit" onclick="abrirEditChofer('${eid}','${cid}')">Editar</button>` : ''}
              ${can('chofDel') || state.auth.role === 'superadmin' ? `<button class="btn-sm danger" onclick="confirmar('¿Eliminar chófer <strong>${c.nombre}</strong>?', ()=>eliminarChofer('${eid}','${cid}'))">Eliminar</button>` : ''}
