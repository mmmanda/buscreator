window.previewCoordsM = function() {
  const raw = document.getElementById('ramalCoordsM').value.trim();
  const countEl = document.getElementById('coordCountM');
  const mapEl = document.getElementById('previewMapM');
  try {
    const coords = JSON.parse(raw);
    if (!Array.isArray(coords) || !coords.length) throw new Error();
    countEl.textContent = `✓ ${coords.length} puntos cargados`;
    mapEl.style.display = 'block'; setTimeout(() => drawRoute(coords, mapEl), 30);
  } catch { countEl.textContent = raw.length > 5 ? '⚠ JSON inválido' : 'Sin coordenadas'; mapEl.style.display = 'none'; }
}

function drawRoute(coords, container) {
  let cv = container.querySelector('canvas');
  if (!cv) { cv = document.createElement('canvas'); container.appendChild(cv); }
  const W = container.clientWidth || 460; const H = 200;
  cv.width = W; cv.height = H;
  Object.assign(cv.style, { position:'absolute', inset:'0', width:'100%', height:'100%' });
  const ctx = cv.getContext('2d'); ctx.clearRect(0, 0, W, H);
  const lons = coords.map(c => c[0]); const lats = coords.map(c => c[1]);
  const minLon=Math.min(...lons), maxLon=Math.max(...lons);
  const minLat=Math.min(...lats), maxLat=Math.max(...lats);
  const pad = 20;
  const toX = lon => pad + (lon-minLon)/(maxLon-minLon||1) * (W-pad*2);
  const toY = lat => H-pad - (lat-minLat)/(maxLat-minLat||1) * (H-pad*2);
  ctx.strokeStyle='#3b82f6'; ctx.lineWidth=1.5; ctx.shadowColor='#3b82f6'; ctx.shadowBlur=4;
  ctx.beginPath();
  coords.forEach((c,i) => i===0 ? ctx.moveTo(toX(c[0]),toY(c[1])) : ctx.lineTo(toX(c[0]),toY(c[1])));
  ctx.stroke();
  [[coords[0],'#22c55e'],[coords[coords.length-1],'#ef4444']].forEach(([pt,col]) => {
    ctx.fillStyle=col; ctx.shadowBlur=0; ctx.beginPath(); ctx.arc(toX(pt[0]),toY(pt[1]),5,0,Math.PI*2); ctx.fill();
  });
}

window.toast = function(msg, type='ok') {
  const el = document.createElement('div');
  el.className = 'toast ' + (type==='error' ? 'error' : '');
  el.textContent = msg;
  document.getElementById('toastContainer').appendChild(el);
  setTimeout(() => el.remove(), 3200);
}

