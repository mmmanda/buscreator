//  LOGICA DE GRILLA DE HORARIOS
// ══════════════════════════════════════════════════════════════════
let grillaCols = 2; 
window.diasSemana = ['L','M','X','J','V','S','D','Feriado'];

window.renderGrillaHeader = function() {
  const tr = document.getElementById('grillaHead');
  let html = `<th>Lugar</th>`;
  for(let i=1; i<=grillaCols; i++) {
    html += `<th>Bus ${i} ${can('ramGridDel') ? `<button type="button" class="btn-del-grid" onclick="removeGridCol(${i})" style="margin-left:4px;" title="Borrar columna de bus">X</button>` : ''}</th>`;
  }
  html += `<th>Días de la semana</th>`;
  if (can('ramGridDel')) html += `<th>Acción</th>`;
  tr.innerHTML = html;
}

window.addGridRow = function(data = null) {
  const tbody = document.getElementById('grillaBody');
  const tr = document.createElement('tr');
  const isDisabled = !can('ramGridEdit') ? 'disabled' : '';
  
  let html = `<td><input type="text" class="g-lugar" placeholder="Ej: Terminal" value="${data ? data.lugar : ''}" ${isDisabled}></td>`;
  
  for(let i=0; i<grillaCols; i++) {
    let timeVal = data && data.horarios && data.horarios[i] ? data.horarios[i] : '';
    html += `<td><input type="time" class="g-time" value="${timeVal}" ${isDisabled} required></td>`;
  }
  
  html += `<td><div class="dias-checkboxes">`;
  window.diasSemana.forEach(d => {
    let isChecked = data && data.dias && data.dias.includes(d) ? 'checked' : '';
    html += `<label><input type="checkbox" class="g-dia" value="${d}" ${isChecked} ${isDisabled}> ${d}</label>`;
  });
  html += `</div></td>`;
  
  if (can('ramGridDel')) {
    html += `<td><button type="button" class="btn-del-grid" onclick="this.closest('tr').remove()">X</button></td>`;
  }
  tr.innerHTML = html;
  tbody.appendChild(tr);
}

window.addGridCol = function() {
  grillaCols++;
  renderGrillaHeader();
  const rows = document.getElementById('grillaBody').querySelectorAll('tr');
  rows.forEach(row => {
    const td = document.createElement('td');
    td.innerHTML = `<input type="time" class="g-time" ${!can('ramGridEdit') ? 'disabled' : ''} required>`;
    const insertBeforeIdx = can('ramGridDel') ? row.children.length - 2 : row.children.length - 1;
    row.insertBefore(td, row.children[insertBeforeIdx]);
  });
}

window.removeGridCol = function(index) {
  if(grillaCols <= 1) return toast('Debe haber al menos un bus (columna)', 'error');
  const currentData = extractGrillaData();
  currentData.forEach(row => row.horarios.splice(index - 1, 1));
  grillaCols--;
  loadGrillaData(currentData);
}

window.extractGrillaData = function() {
  const rows = document.getElementById('grillaBody').querySelectorAll('tr');
  const data = [];
  rows.forEach(row => {
    const lugar = row.querySelector('.g-lugar').value.trim();
    const horarios = Array.from(row.querySelectorAll('.g-time')).map(inp => inp.value);
    const dias = Array.from(row.querySelectorAll('.g-dia:checked')).map(chk => chk.value);
    if (lugar || horarios.some(h => h !== '')) {
      data.push({ lugar, horarios, dias });
    }
  });
  return data;
}

window.loadGrillaData = function(dataArr) {
  const tbody = document.getElementById('grillaBody');
  tbody.innerHTML = '';
  document.getElementById('grillaControls').style.display = can('ramGridAdd') ? 'flex' : 'none';
  
  if (dataArr && dataArr.length > 0) {
    grillaCols = Math.max(...dataArr.map(d => (d.horarios ? d.horarios.length : 1)));
    renderGrillaHeader();
    dataArr.forEach(d => addGridRow(d));
  } else {
    grillaCols = 2; 
    renderGrillaHeader();
    if(can('ramGridAdd')) { addGridRow(); addGridRow(); addGridRow(); }
  }
}

