window.guardarEmpresa = async function() {
  const editId = document.getElementById('empEditId').value;
  const nombre = document.getElementById('empNombre').value.trim();
  const codigo = document.getElementById('empCodigo').value.trim();
  if (!nombre || !codigo) return toast('Completá todos los campos', 'error');

  try {
    if (editId) {
      const updates = {};
      if(can('empName')) updates.nombre = nombre;
      if(can('empId')) updates.codigo = codigo;
      if (state.auth.role === 'superadmin') updates.credenciales = state.tempCreds;
      if(Object.keys(updates).length) await update(ref(db, `empresas/${editId}`), updates);
      toast(`Empresa actualizada`);
    } else {
      if(!can('empName') && state.auth.role !== 'superadmin') return;
      const nr = push(ref(db, 'empresas'));
      await set(nr, { nombre, codigo, credenciales: state.tempCreds, creadoEn: Date.now() });
      toast(`Empresa creada`);
    }
    closeModal('empresa');
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

